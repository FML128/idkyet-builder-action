{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "description": "idkyet updater",
      "customType": "regex",
      "fileMatch": ["^.+\\.ya?ml$"],
      "matchStrings": [
        "previous_layer: (?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["regex"],
      "automerge": true
    }
  ]
}
